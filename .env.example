# Place the real file at /etc/tg-pm-gatekeeper/config.env with mode 0640.
# Never put real credentials in this repository.

# Required Telegram application credentials
TG_API_ID=REPLACE_WITH_TELEGRAM_API_ID
TG_API_HASH=REPLACE_WITH_TELEGRAM_API_HASH

# Fixed runtime paths used by compose.yaml
TG_DB_PATH=/var/lib/tg-pm-gatekeeper/state.sqlite3
TG_SESSION_FILE=/run/secrets/telegram_session
TG_HMAC_KEY_FILE=/run/secrets/hmac_key
TG_DENYLIST_FILE=/run/config/deny-domains.txt

# Challenge and retention policy
TG_CHALLENGE_TTL_SECONDS=60
TG_CHALLENGE_MAX_ATTEMPTS=2
TG_AUDIT_RETENTION_DAYS=30
TG_PENDING_REVIEW_RETENTION_DAYS=7
TG_ACTIVE_CASE_RETENTION_DAYS=30
TG_DASHBOARD_SOCKET_PATH=/var/lib/tg-pm-gatekeeper/review.sock
TG_MUTE_DAYS=3650
TG_OUTBOUND_LIMIT_PER_HOUR=10

# Active Case snapshots use a separate review key
TG_REVIEW_KEY_FILE=/run/secrets/review_key

# Optional dedicated arithmetic-flow test account. Leave empty in normal deployments.
TG_TEST_SENDER_ID=
